<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shop_title"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="24dp" />

        <!-- Row 1: BMW M3 and Mercedes CLA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- BMW M3 Card -->
            <LinearLayout
                android:id="@+id/card_bmw"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_bmw"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bmw_m3"
                    android:background="@drawable/car_image_rounded"
                    android:clipToOutline="true"
                    android:contentDescription="BMW M3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMW M3 (F80 generation)"
                    android:textSize="14sp"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$38,000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mercedes CLA Card -->
            <LinearLayout
                android:id="@+id/card_mercedes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_mercedes"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mercedes_cla"
                    android:background="@drawable/car_image_rounded"
                    android:clipToOutline="true"
                    android:contentDescription="Mercedes CLA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mercedes-Benz CLA-Class (Second Generation)"
                    android:textSize="14sp"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$46,400"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Porsche 911 and Ferrari 488 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Porsche 911 Card -->
            <LinearLayout
                android:id="@+id/card_porsche"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_porsche"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/porsche_911"
                    android:background="@drawable/car_image_rounded"
                    android:clipToOutline="true"
                    android:contentDescription="Porsche 911" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Porsche 911 GT3 RS (991.1 Generation)"
                    android:textSize="14sp"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$189,000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Ferrari 488 Card -->
            <LinearLayout
                android:id="@+id/card_ferrari"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_ferrari"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ferrari_488"
                    android:background="@drawable/car_image_rounded"
                    android:clipToOutline="true"
                    android:contentDescription="Ferrari 488" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ferrari 488 Spider"
                    android:textSize="14sp"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$260,000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
