<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp">

    <!-- Checkmark Circle Icon -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_check_circle" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_checkmark"
            android:contentDescription="Checkmark" />
    </FrameLayout>

    <!-- Done Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/done_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/dark_text"
        android:layout_marginBottom="8dp" />

    <!-- Success Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/done_message"
        android:textSize="16sp"
        android:textColor="@color/gray_text"
        android:layout_marginBottom="32dp" />

    <!-- Go To First Page Button -->
    <TextView
        android:id="@+id/btn_go_first_page"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="@string/go_to_first_page"
        android:textSize="16sp"
        android:textColor="@color/dark_text"
        android:background="@drawable/go_button_bg"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
